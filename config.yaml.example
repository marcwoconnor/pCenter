# pCenter Configuration
# Copy to config.yaml and fill in your values.
#
# Recommended: leave `clusters:` unset and add hosts through the web UI. pCenter
# probes /cluster/status on add and routes to a real PVE cluster or a standalone
# host under a datacenter automatically.
#
# Legacy bootstrap — optional. Each entry is probed on first start: real PVE
# clusters become pcenter clusters; single-node entries become standalone hosts
# under the auto-created "Default" datacenter. The `name` field here is only a
# legacy label; the pcenter cluster's real name comes from PVE's /cluster/status.
# clusters:
#   - name: legacy-bootstrap
#     discovery_node: 10.31.10.14:8006
#     token_id: root@pam!pcenter
#     token_secret: ${PVE_TOKEN_SECRET}
#     insecure: true

# Background polling of PVE clusters (default: true when clusters configured)
poller:
  enabled: true

# DRS settings (optional)
drs:
  enabled: false
  mode: manual  # manual | semi-automatic | fully-automatic
  check_interval: 300  # seconds
  cpu_threshold: 0.8   # trigger when node CPU > 80%
  mem_threshold: 0.85  # trigger when node memory > 85%

auth:
  enabled: true
  encryption_key: ${PCENTER_ENCRYPTION_KEY}  # Auto-generated on first run

server:
  port: 8080
  cors_origins:
    - http://localhost:5173  # Vite dev server
    - http://localhost:3000


# Legacy format (auto-converts to single "default" cluster):
# nodes:
#   - name: pve04
#     host: 10.31.11.1:8006
#     token_id: root@pam!pcenter
#     token_secret: ${PVE_TOKEN_SECRET}
#     insecure: true
